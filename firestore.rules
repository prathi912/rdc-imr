

  rules_version = '2';

  service cloud.firestore {
    match /databases/{database}/documents {

      function isSuperAdmin() {
        let user = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return isSignedIn() && user != null && user.data != null && user.data.role == 'Super-admin';
      }

      function isAdmin() {
        if (!isSignedIn()) return false;
        let user = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return user != null && user.data != null && (user.data.role == 'admin' || user.data.role == 'Super-admin');
      }
      
      function isCRO() {
        if (!isSignedIn()) return false;
        let user = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return user != null && user.data != null && user.data.role == 'CRO';
      }

      function isOwner(userId) {
        return isSignedIn() && request.auth.uid == userId;
      }
      
      function isFaculty() {
        if (!isSignedIn()) return false;
        let user = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return user != null && user.data != null && user.data.role == 'faculty';
      }
      
      function isEvaluator() {
        if (!isSignedIn()) return false;
        let user = get(/databases/$(database)/documents/users/$(request.auth.uid));
        return user != null && user.data != null && user.data.role == 'Evaluator';
      }
      
      function isSignedIn() {
        return request.auth != null;
      }

      match /users/{userId} {
        // Allow a user to create their own user document, but prohibit setting a role.
        // Roles must be assigned by an admin or a server-side process.
        allow create: if request.auth.uid == userId && !('role' in request.resource.data);

        // Users can read their own profile, Admins/Super-admins can read any profile.
        // We allow any signed-in user to 'get' a specific profile (for name resolution), 
        // but only admins can 'list' (query) the users collection.
        allow get: if isSignedIn();
        allow list: if isAdmin();
        
        // Users can update their own profile, but cannot change their role.
        // Admins/Super-admins can update any user profile.
        allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();

        // Only Super-admins can delete users, but not themselves or the primary super admin.
        allow delete: if isSuperAdmin() && request.auth.uid != userId && resource.data.email != 'rathipranav07@gmail.com';
      }

      match /projects/{projectId} {
        // Any signed-in user can create a project (as a draft).
        allow create: if isSignedIn();

        // Read access: The PI, Co-PIs, assigned evaluators, and admins/CROs can read.
        allow read: if isSignedIn() && (
                      resource.data.pi_uid == request.auth.uid || 
                      (resource.data.pi_email != null && request.auth.token.email != null && resource.data.pi_email.lower() == request.auth.token.email.lower()) ||
                      (resource.data.coPiUids != null && request.auth.uid in resource.data.coPiUids) ||
                      (resource.data.meetingDetails != null && request.auth.uid in resource.data.meetingDetails.assignedEvaluators) ||
                      isAdmin() || 
                      (isCRO() && (resource.data.faculty in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.faculties))
                    );
        
        // Update access: The PI can update their own project. Admins can update any project.
        allow update: if isSignedIn() && (resource.data.pi_uid == request.auth.uid || isAdmin());
        
        // Delete access: Only admins can delete projects.
        allow delete: if isAdmin();
        
        match /evaluations/{evaluationId} {
          // Create/Update: Only assigned evaluators for this project can create or update an evaluation.
          allow write: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.meetingDetails.assignedEvaluators;
          // Read: The PI, Admins, and the evaluator who wrote it can read an evaluation.
          allow read: if isSignedIn() && (isOwner(evaluationId) || isAdmin() || get(/databases/$(database)/documents/projects/$(projectId)).data.pi_uid == request.auth.uid);
        }
      }

      match /incentiveClaims/{claimId} {
          // Any signed-in user can create a claim.
          allow create: if isSignedIn();
          // Read: The user who created the claim, co-authors, or an admin/CRO can read it.
          allow read: if isSignedIn() && (
                        resource.data.uid == request.auth.uid || 
                        (resource.data.authorUids != null && request.auth.uid in resource.data.authorUids) ||
                        (resource.data.authorEmails != null && request.auth.token.email != null && request.auth.token.email.lower() in resource.data.authorEmails) ||
                        isAdmin() || 
                        isCRO()
                      );
          // Update/Delete: Only admins can update or delete claims.
          allow update, delete: if isAdmin();
      }
      
      match /notifications/{notificationId} {
          // Users can only read their own notifications.
          allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
          // Users can update their own notifications (e.g., mark as read).
          allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
          // Notifications are created by server-side actions, so no client-side creation.
          allow create, delete: if false;
      }
      
      match /fundingCalls/{callId} {
        // All signed-in users can view funding calls.
        allow read: if isSignedIn();
        // Only Super-admins can create, update, or delete calls.
        allow write: if isSuperAdmin();
      }
      
      match /emrInterests/{interestId} {
          // Users can create their own interest registrations. Admins can create on behalf of users.
          allow create: if isSignedIn() && (isOwner(request.resource.data.userId) || isAdmin());
          
          // Users can delete their own interest registrations. Admins can delete any registration.
          allow delete: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());

          // Users can update their own registrations (e.g., upload PPT).
          // Admins can update any registration (e.g., set status).
          allow update: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
          
          // All signed-in users can read EMR interests.
          allow read: if isSignedIn();
          
          match /evaluations/{evaluatorId} {
              // Evaluators can write their own evaluation.
              allow write: if isSignedIn() && isOwner(evaluatorId);
              // Admins can read all evaluations.
              allow read: if isSignedIn() && isAdmin();
          }
      }
      
      match /projectRecruitments/{recruitmentId} {
        allow read: if true; // Publicly readable
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (resource.data.postedByUid == request.auth.uid || isSuperAdmin());
        allow delete: if isSignedIn() && (resource.data.postedByUid == request.auth.uid || isSuperAdmin());
        
        match /applications/{applicationId} {
            allow create: if true; // Public can apply
            allow read: if isSignedIn() && (
              get(/databases/$(database)/documents/projectRecruitments/$(recruitmentId)).data.postedByUid == request.auth.uid ||
              isSuperAdmin()
            );
        }
      }

      // Health check collection is restricted to admins.
      match /_health_check/{docId} {
        allow read, write: if isAdmin();
      }

      // System Auditing Collections - Read restricted to Admins/Super-admins
      match /system_logs/{logId} {
        allow read: if isAdmin();
        allow write: if false; 
      }

      match /change_history/{historyId} {
        allow read: if isAdmin();
        allow write: if false;
      }

      match /access_audit/{auditId} {
        allow read: if isSuperAdmin();
        allow write: if false;
      }

      match /policy_traces/{traceId} {
        allow read: if isSuperAdmin();
        allow write: if false;
      }

      match /financial_ledger/{txnId} {
        allow read: if isSuperAdmin();
        allow write: if false;
      }
    }
  }
