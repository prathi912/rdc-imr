
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
  
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'Super-admin'];
    }
    
    // Profile pictures can be read by anyone (for public profiles), but only written by the owner.
    match /profile-pictures/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
    
    // Project files: PI, Co-PIs, and admins can read. PI can write.
    match /projects/{projectId}/{folder}/{fileName} {
      allow read: if request.auth != null && (
          get(/databases/(default)/documents/projects/$(projectId)).data.pi_uid == request.auth.uid ||
          request.auth.uid in get(/databases/(default)/documents/projects/$(projectId)).data.coPiUids ||
          isAdmin()
      );
      allow write: if request.auth != null && get(/databases/(default)/documents/projects/$(projectId)).data.pi_uid == request.auth.uid;
    }
    
    // Incentive claim proofs: ONLY the user submitting them and admins.
    match /incentive-proofs/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // EMR presentations: Owner, Admins, and potentially evaluators.
    match /emr-presentations/{callId}/{userId}/{fileName} {
      // For now, restrict to owner and admins. Evaluators can be added if needed via project-specific checks.
      allow read: if request.auth != null && (isOwner(userId) || isAdmin()); 
      allow write: if isOwner(userId);
    }
    
     match /emr-attachments/{callId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    // Invoice files: PI and admins.
    match /invoices/{projectId}/{phaseId}/{fileName} {
       allow read: if request.auth != null && (
         get(/databases/(default)/documents/projects/$(projectId)).data.pi_uid == request.auth.uid ||
         isAdmin()
       );
       allow write: if request.auth != null && get(/databases/(default)/documents/projects/$(projectId)).data.pi_uid == request.auth.uid;
    }
    
    // Completion reports: PI and admins.
    match /reports/{projectId}/{folder}/{fileName} {
       allow read: if request.auth != null && (
         get(/databases/(default)/documents/projects/$(projectId)).data.pi_uid == request.auth.uid ||
         isAdmin()
       );
       allow write: if request.auth != null && get(/databases/(default)/documents/projects/$(projectId)).data.pi_uid == request.auth.uid;
    }

    // General uploads: Authenticated users can read (to see project files), and the uploader/owner can write.
    match /uploads/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
